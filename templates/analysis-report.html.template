<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analysis — {{REPORT_TITLE}}</title>
  <link rel="stylesheet" href="../research.css">
</head>
<!-- ANALYSIS REPORT — the deliverable of an analysis/writing task. The rule:
     every quantitative claim cites an experiment card ID or dataset ID. A number
     with no traceable source does not go in. Lives beside the card it belongs to
     (experiments/E*/) or in a dedicated analysis folder; adjust ../ paths to match. -->
<body>
<div class="page-wrap">

  <nav class="sidebar" aria-label="Table of contents">
    <div class="sidebar-brand">
      <div class="sidebar-brand-name">{{PROJECT_SHORT_NAME}}
        <span>analysis report</span>
      </div>
    </div>
    <p class="sidebar-title">Contents</p>
    <div id="toc-list"></div>
  </nav>

  <div class="main-content">
    <header class="spec-header">
      <h1>Analysis — {{REPORT_TITLE}}</h1>
      <table class="meta-table">
        <tbody>
          <tr><th>Author</th> <td>analyst</td></tr>
          <tr><th>Date</th>   <td>{{DATE}}</td></tr>
          <tr><th>Inputs</th> <td>{{CARD_IDS_AND_DATASET_IDS}}</td></tr>
          <tr><th>Status</th> <td><span class="badge badge-draft">draft</span></td></tr>
        </tbody>
      </table>
    </header>

    <main>
      <section id="question">
        <h2>Question</h2>
        <p>{{ANALYSIS_QUESTION}}</p>
      </section>

      <section id="inputs">
        <h2>Inputs</h2>
        <table>
          <thead><tr><th>ID</th><th>Kind</th><th>Source</th></tr></thead>
          <tbody>
            <tr><td><code>{{CARD_ID}}</code></td><td>experiment</td><td><a href="../{{CARD_ID}}/card.html">card</a></td></tr>
            <tr><td><code>{{DATASET_ID}}</code></td><td>dataset</td><td>{{DATASET_SOURCE}}</td></tr>
          </tbody>
        </table>
      </section>

      <section id="method">
        <h2>Method</h2>
        <p>{{METHOD}}</p>
      </section>

      <section id="findings">
        <h2>Findings</h2>
        <!-- Every number cites its source ID. Use the citation inline, e.g.
             "accuracy 0.869 (E012)". Figures name their generating script. -->
        <p>{{FINDINGS_WITH_CITATIONS}}</p>
        <div class="claude-note">
          <h4>Figure provenance</h4>
          <p>{{FIGURE}}: generated by <code>{{FIGURE_SCRIPT}}</code> from {{FIGURE_INPUTS}}.</p>
        </div>
      </section>

      <section id="limitations">
        <h2>Limitations</h2>
        <ul>
          <li>{{LIMITATION}}</li>
        </ul>
      </section>

      <section id="next">
        <h2>Suggested next experiments</h2>
        <ul>
          <li>{{NEXT_EXPERIMENT}}</li>
        </ul>
      </section>
    </main>
  </div>
</div>
<script src="../research.js"></script>
</body>
</html>
