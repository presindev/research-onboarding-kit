<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ID}} — {{TITLE}}</title>
  <link rel="stylesheet" href="../research.css">
</head>
<!-- EXPERIMENT CARD — the kit's central artifact. One card = one experiment =
     one config. Rules enforced by this template's structure:
       * exactly ONE change under test;
       * metrics + gate criteria are declared BEFORE launch (filled at `approved`);
       * the Results section is filled ONLY from real outputs — never "expected"
         numbers, never before the run returns;
       * the design sections are append-only after approval — corrections append,
         they do not overwrite (a re-run varying the same axis gets a NEW card,
         e.g. {{ID}}__v2 with a `supersedes:` field).
     research.css/research.js live one level up at experiments/research.{css,js}
     (one shared copy per experiments/ tree). Adjust the ../ paths if your layout
     differs. -->
<body>
<div class="page-wrap">

  <nav class="sidebar" aria-label="Table of contents">
    <div class="sidebar-brand">
      <div class="sidebar-brand-name">{{PROJECT_SHORT_NAME}}
        <span>experiment card</span>
      </div>
    </div>
    <p class="sidebar-title">Contents</p>
    <div id="toc-list"></div>
  </nav>

  <div class="main-content">
    <header class="spec-header">
      <h1>{{ID}} — {{TITLE}}</h1>
      <table class="meta-table">
        <tbody>
          <tr><th>Experiment ID</th><td><code>{{ID}}</code></td></tr>
          <tr><th>Status</th>       <td><span class="badge badge-draft">draft</span></td></tr>
          <tr><th>Plan ref</th>     <td>{{PLAN_REF}}</td></tr>
          <tr><th>Supersedes</th>   <td>{{SUPERSEDES_OR_NONE}}</td></tr>
          <tr><th>Approver</th>     <td>{{APPROVER}}</td></tr>
          <tr><th>Smoke test</th>   <td><span class="smoke smoke-missing">smoke: not yet passed</span></td></tr>
        </tbody>
      </table>
      <!-- Status badge classes: badge-draft → badge-approved → badge-launched →
           badge-analyzed → badge-done | badge-failed | badge-abandoned.
           Update the badge AND the experiments/registry.json record together —
           registry.json is the validation source of truth. -->
    </header>

    <main>

      <section id="lifecycle">
        <h2>Lifecycle</h2>
        <ol class="task-timeline exp-timeline">
          <li class="task-item draft"><div class="task-item-header"><span class="badge badge-draft">draft</span> Card drafted</div><div class="task-item-body">{{DRAFT_NOTE_OR_TODO}}</div></li>
          <li class="task-item"><div class="task-item-header"><span class="badge badge-approved">approved</span> ⛔ Researcher approves</div><div class="task-item-body">No config, launcher, or run before this.</div></li>
          <li class="task-item"><div class="task-item-header"><span class="badge badge-launched">launched</span> Submitted / running</div><div class="task-item-body">Registry row created; no fabricated results.</div></li>
          <li class="task-item"><div class="task-item-header"><span class="badge badge-analyzed">analyzed</span> Results collected</div><div class="task-item-body">Verified vs gate; skeptic refutation done.</div></li>
          <li class="task-item"><div class="task-item-header"><span class="badge badge-done">done</span> ⛔ Verdict confirmed</div><div class="task-item-body">Registry + notebook updated.</div></li>
        </ol>
        <!-- As the experiment advances, add the matching state class
             (approved/launched/analyzed/done/failed) to each <li> so its node
             colors in. -->
      </section>

      <section id="hypothesis">
        <h2>Hypothesis / question</h2>
        <div class="req-row"><span class="req-id">H</span><span>{{HYPOTHESIS}}</span></div>
      </section>

      <section id="change-under-test">
        <h2>Change under test (exactly one)</h2>
        <div class="req-row ac"><span class="req-id ac">CHANGE</span><span>{{SINGLE_CHANGE}}</span></div>
        <p>Everything else is held identical to the baseline. If this card needs
           more than one change, it is more than one experiment — split it.</p>
      </section>

      <section id="baseline">
        <h2>Baseline</h2>
        <p>{{BASELINE_CARD_ID_OR_NAMED_RESULT}}</p>
        <!-- A card ID (e.g. E011_baseline) or a named reference result. A new
             experiment with no baseline is usually a baseline-reproduction card
             first. -->
      </section>

      <section id="setup">
        <h2>Setup</h2>
        <table>
          <tbody>
            <tr><td>Config</td>       <td><code>{{CONFIG_PATH}}</code></td></tr>
            <tr><td>Launcher</td>     <td><code>{{LAUNCHER_PATH}}</code></td></tr>
            <tr><td>Code version</td> <td><code>{{GIT_SHA}}</code> {{DIRTY_FLAG_OR_CLEAN}}</td></tr>
            <tr><td>Data</td>         <td>{{DATASET_IDS_AND_CHECKSUMS}}</td></tr>
            <tr><td>Frozen inputs</td><td>{{FROZEN_IDS_OR_NONE}} — verify with <code>check_frozen.py</code></td></tr>
            <tr><td>Environment</td>  <td>{{ENV_CAPTURE_REF}}</td></tr>
            <tr><td>Seeds</td>        <td>{{SEEDS}}</td></tr>
            <tr><td>Budget</td>       <td>{{GPU_H_OR_WALLTIME}}</td></tr>
            <tr><td>Smoke test</td>   <td><code>{{SMOKE_COMMAND}}</code> → {{SMOKE_PASSED_DATE_OR_TODO}}</td></tr>
          </tbody>
        </table>
      </section>

      <section id="metrics-gate">
        <h2>Metrics &amp; gate criteria (declared BEFORE launch)</h2>
        <!-- Filled when the card moves to `approved`. Frozen for this run once
             approved; changing it afterward requires a dated decision entry. -->
        <div class="metric-row"><span class="req-id m">{{METRIC_ID}}</span><span>{{METRIC_DESCRIPTION}}</span></div>
        <div class="gate-row"><span class="req-id gate">GATE</span><span>{{GATE_CRITERION}}</span></div>
      </section>

      <section id="results">
        <h2>Results</h2>
        <!-- Filled ONLY from real outputs after the run returns. Link the artifact
             files (metrics json, plots) in results/{{ID}}/. Failures and negative
             results are recorded here with the same discipline as wins. -->
        <p>{{RESULTS_TODO_UNTIL_RUN_RETURNS}}</p>
        <table>
          <thead><tr><th>Metric</th><th>Baseline</th><th>This run</th><th>Gate</th><th>Verdict</th></tr></thead>
          <tbody>
            <tr><td>{{METRIC_ID}}</td><td>{{BASELINE_VALUE}}</td><td>{{RUN_VALUE}}</td><td>{{GATE_THRESHOLD}}</td><td class="{{PASS_FAIL_INCONCLUSIVE}}">{{VERDICT_CELL}}</td></tr>
          </tbody>
        </table>
        <p>Artifacts: {{LINKS_TO_RESULTS_FILES}}</p>
      </section>

      <section id="integrity">
        <h2>Integrity checks</h2>
        <div class="frozen-warning">
          <h4>Frozen / leakage check</h4>
          {{FROZEN_AND_LEAKAGE_NOTE}}
        </div>
        <div class="claude-note">
          <h4>Skeptic notes</h4>
          <ol>
            <li>{{SKEPTIC_POINT_1}}</li>
            <li>{{SKEPTIC_POINT_2_OR_REMOVE}}</li>
          </ol>
        </div>
        <!-- The skeptic tries to REFUTE the verdict before it is proposed:
             statistical validity, calibration, leakage, baseline fairness,
             claim–artifact traceability, seed variance. -->
      </section>

      <section id="verdict">
        <h2>Verdict vs gate</h2>
        <p><strong>Proposed verdict:</strong> {{PROPOSED_VERDICT}}</p>
        <table class="meta-table">
          <tbody>
            <tr><th>Gate met?</th>   <td>{{PASS_FAIL_INCONCLUSIVE_TEXT}}</td></tr>
            <tr><th>Proposed by</th> <td>Claude (analyst + skeptic)</td></tr>
            <tr><th>Confirmed by</th><td>{{APPROVER}} — <span class="badge badge-pending">pending</span></td></tr>
          </tbody>
        </table>
        <!-- ⛔ Claude proposes; the approver confirms. Only a confirmed verdict
             moves a PLAN gate and may propose a decision-log entry. -->
      </section>

      <section id="follow-ups">
        <h2>Follow-ups / decisions proposed</h2>
        <ul>
          <li>{{FOLLOW_UP_OR_NEXT_CARD}}</li>
        </ul>
      </section>

    </main>
  </div>
</div>
<script src="../research.js"></script>
</body>
</html>
