<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Experiment registry — {{PROJECT_NAME}}</title>
  <link rel="stylesheet" href="research.css">
</head>
<!-- EXPERIMENT REGISTRY (dashboard). Human-facing view of experiments/registry.json.
     registry.json is the validation source of truth; keep this table consistent
     with it (validate_registry.py checks the JSON, not this HTML). Add one row per
     experiment using the row template in the comment below. -->
<body>
<div class="page-wrap">

  <nav class="sidebar" aria-label="Table of contents">
    <div class="sidebar-brand">
      <div class="sidebar-brand-name">{{PROJECT_SHORT_NAME}}
        <span>experiment registry</span>
      </div>
    </div>
    <p class="sidebar-title">Contents</p>
    <div id="toc-list"></div>
  </nav>

  <div class="main-content">
    <header class="spec-header">
      <h1>Experiment registry — {{PROJECT_NAME}}</h1>
      <p>One row per experiment. Source of truth: <code>experiments/registry.json</code>.
         ID convention: <code>{{ID_CONVENTION}}</code>.</p>
    </header>

    <main>
      <section id="active">
        <h2>Experiments</h2>
        <table>
          <thead>
            <tr><th>ID</th><th>Title</th><th>Status</th><th>Gate</th><th>Plan ref</th><th>Card</th></tr>
          </thead>
          <tbody>
            <!-- ROW TEMPLATE — copy per experiment; set the status badge class and
                 the gate cell class (pass/fail/inconclusive) to match registry.json.
            <tr>
              <td><code>E001_slug</code></td>
              <td>title</td>
              <td><span class="badge badge-launched">launched</span></td>
              <td class="inconclusive">pending</td>
              <td>PLAN.md §1</td>
              <td><a href="E001_slug/card.html">card</a></td>
            </tr>
            -->
            <tr><td colspan="6" style="color:var(--text-muted);font-style:italic;">No experiments yet. The first card is usually a baseline reproduction.</td></tr>
          </tbody>
        </table>
        <!-- Status badges: badge-draft / badge-approved / badge-launched /
             badge-analyzed / badge-done / badge-failed / badge-abandoned.
             Gate cell classes: pass / fail / inconclusive (or plain for pending). -->
      </section>

      <section id="superseded">
        <h2>Superseded / abandoned</h2>
        <p>{{SUPERSEDED_LIST_OR_NONE}}</p>
      </section>
    </main>
  </div>
</div>
<script src="research.js"></script>
</body>
</html>
