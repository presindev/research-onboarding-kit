<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{DOC_TITLE}}</title>
  <link rel="stylesheet" href="../research.css">
</head>
<!-- GENERIC RDD DOCUMENT — reach for this whenever you would otherwise write an
     ad-hoc human-facing spec, design note, plan, or proposal as plain Markdown.
     Any document a human is meant to READ uses this styled design system, not raw
     Markdown. (Claude-facing operational files — CLAUDE.md, skills, agents, the
     project map, decision logs — stay Markdown by design; this is only for
     human-readable specs/notes/reports.)
     For a hypothesis test use experiment-card.html.template; for infrastructure use
     infra-spec.html.template; for interpreting results use analysis-report.html.template.
     This template is the catch-all for everything else.
     Lives in a folder with research.css/research.js one level up (e.g. specs/<topic>/,
     docs/<topic>/). Copy research.css/research.js next to it; adjust ../ if needed.
     Keep, drop, or repeat sections as the document needs — the TOC builds itself
     from the <h2>/<h3> headings. -->
<body>
<div class="page-wrap">

  <nav class="sidebar" aria-label="Table of contents">
    <div class="sidebar-brand">
      <div class="sidebar-brand-name">{{PROJECT_SHORT_NAME}}
        <span>{{DOC_KIND}}</span>
      </div>
    </div>
    <p class="sidebar-title">Contents</p>
    <div id="toc-list"></div>
  </nav>

  <div class="main-content">
    <header class="spec-header">
      <h1>{{DOC_TITLE}}</h1>
      <table class="meta-table">
        <tbody>
          <tr><th>Kind</th>      <td>{{DOC_KIND}}</td></tr>
          <tr><th>Author</th>    <td>{{AUTHOR}}</td></tr>
          <tr><th>Date</th>      <td>{{DATE}}</td></tr>
          <tr><th>Status</th>    <td><span class="badge badge-draft">draft</span></td></tr>
          <tr><th>Related</th>   <td>{{RELATED_CARDS_OR_PLAN_REF_OR_NONE}}</td></tr>
        </tbody>
      </table>
      <!-- Status badge classes: badge-draft / badge-pending / badge-ok /
           badge-approved / badge-warning / badge-blocking / badge-rejected. -->
    </header>

    <main>

      <section id="summary">
        <h2>Summary</h2>
        <p>{{ONE_PARAGRAPH_SUMMARY}}</p>
      </section>

      <section id="context">
        <h2>Context</h2>
        <p>{{WHY_THIS_DOCUMENT_EXISTS}}</p>
      </section>

      <section id="body">
        <h2>{{SECTION_HEADING}}</h2>
        <p>{{SECTION_BODY}}</p>
        <!-- Duplicate this <section> per topic. Use the shared components as needed:
             <pre><code>…</code></pre> for code/interfaces, <table> for comparisons,
             <div class="req-row"><span class="req-id">…</span><span>…</span></div> for
             tagged statements, and <div class="claude-note"> for an assistant note. -->
      </section>

      <section id="open-questions">
        <h2>Open questions / next steps</h2>
        <ul>
          <li>{{OPEN_QUESTION_OR_NEXT_STEP}}</li>
        </ul>
      </section>

    </main>
  </div>
</div>
<script src="../research.js"></script>
</body>
</html>
